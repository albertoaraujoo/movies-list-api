# ============================================================
# BANCO DE DADOS
# ============================================================
# ATENÇÃO: se sua senha contém "@", encode como "%40" na URL
# Exemplo: senha "@MinhaS3nha" → ...postgres:%40MinhaS3nha@host...
DATABASE_URL="postgresql://postgres:senha@db.xxxx.supabase.co:5432/postgres?sslmode=require"

# ============================================================
# JWT
# ============================================================
# Gere um segredo com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="cole-aqui-uma-chave-aleatoria-de-no-minimo-32-chars"
JWT_EXPIRES_IN="7d"

# ============================================================
# GOOGLE OAUTH
# ============================================================
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"

# ============================================================
# TMDB
# ============================================================
# themoviedb.org → Settings → API → "API Read Access Token" (campo longo — NÃO a API Key)
TMDB_ACCESS_TOKEN="eyJhbGciOiJSUzI1NiJ9..."
TMDB_BASE_URL="https://api.themoviedb.org/3"
TMDB_IMAGE_URL="https://image.tmdb.org/t/p/w500"

# ============================================================
# SERVIDOR
# ============================================================
PORT=3000
NODE_ENV="development"

# URL do frontend — OBRIGATÓRIO em produção (NODE_ENV=production)
# Em desenvolvimento pode deixar em branco
FRONTEND_URL="https://seu-frontend.vercel.app"
