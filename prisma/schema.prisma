// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProfilePrivacy {
  public
  private
  friends
}

enum ActivityType {
  movie_watched
  list_created
}

enum NotificationType {
  user_followed
}

model User {
  id         String         @id @default(uuid())
  email      String         @unique
  name       String
  image      String?
  googleId   String         @unique
  username   String?        @unique
  usernameUpdatedAt DateTime?
  nameEditedAt      DateTime?
  privacy    ProfilePrivacy @default(public)
  bio        String?
  movies     Movie[]
  lists      MovieList[]
  reviews    Review[]
  reviewLikes    ReviewLike[]
  reviewComments ReviewComment[]
  activities ActivityLog[]
  followers  UserFollow[]   @relation("Following")
  following  UserFollow[]   @relation("Follower")
  notificationsReceived Notification[] @relation("NotificationsReceived")
  notificationsSent     Notification[] @relation("NotificationsSent")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@map("users")
}

model UserFollow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("user_follows")
}

model Movie {
  id               String          @id @default(uuid())
  title            String
  director         String?
  year             Int?
  notes            String?
  watched          Boolean         @default(false)
  tmdbId           Int?
  posterPath       String?
  overview         String?
  runtime          Int?
  watchProvidersBr Json?
  userRating       Float?
  genres           String[]        @default([])
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  drawn            DrawnMovie?
  review           Review?
  listItems        MovieListItem[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId])
  @@index([userId, watched])
  @@map("movies")
}

model Review {
  id        String    @id @default(uuid())
  text      String
  watchedAt DateTime?
  movieId   String    @unique
  userId    String
  movie     Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     ReviewLike[]
  comments  ReviewComment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@map("reviews")
}

model ReviewLike {
  reviewId  String
  userId    String
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([reviewId, userId])
  @@index([userId])
  @@map("review_likes")
}

model ReviewComment {
  id        String          @id @default(uuid())
  text      String
  reviewId  String
  userId    String
  parentId  String?
  review    Review          @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    ReviewComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ReviewComment[] @relation("CommentThread")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([reviewId, createdAt])
  @@index([parentId])
  @@map("review_comments")
}

model MovieList {
  id          String          @id @default(uuid())
  name        String
  description String?
  isDefault   Boolean         @default(false)
  isFavorites Boolean         @default(false)
  isNumbered  Boolean         @default(false)
  isRanked    Boolean         @default(false)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       MovieListItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
  @@index([userId, isFavorites])
  @@map("movie_lists")
}

model MovieListItem {
  id      String    @id @default(uuid())
  listId  String
  movieId String
  order   Int       @default(0)
  list    MovieList @relation(fields: [listId], references: [id], onDelete: Cascade)
  movie   Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([listId, movieId])
  @@index([listId, order])
  @@map("movie_list_items")
}

model ActivityLog {
  id        String       @id @default(uuid())
  type      ActivityType
  userId    String
  metadata  Json
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([userId, createdAt])
  @@map("activity_logs")
}

model DrawnMovie {
  id      String   @id @default(uuid())
  movieId String   @unique
  movie   Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  order   Int
  drawnAt DateTime @default(now())

  @@map("drawn_movies")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  actorId   String
  type      NotificationType
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation("NotificationsReceived", fields: [userId], references: [id], onDelete: Cascade)
  actor     User             @relation("NotificationsSent", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}
